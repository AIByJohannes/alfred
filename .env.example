# OpenRouter
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# FastAPI bridge
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Frontend bridge
CORS_ORIGINS=http://localhost:5173

# Local runtime
ALFRED_RUNTIME_ROOT=.alfred-runtime
ALFRED_AGENT_MODE=fs-agent

# Optional explicit binary override
ALFRED_CLI_BIN=

# Transcription (optional, requires faster-whisper)
# ALFRED_TRANSCRIBE_BACKEND=faster-whisper
# ALFRED_TRANSCRIBE_MODEL=openai/whisper-large-v3-turbo
# ALFRED_TRANSCRIBE_DEVICE=cuda
# ALFRED_TRANSCRIBE_COMPUTE_TYPE=float16
# ALFRED_TRANSCRIBE_LANGUAGE=auto
# ALFRED_TRANSCRIBE_WORD_TIMESTAMPS=false
# ALFRED_TRANSCRIBE_VAD=true
# ALFRED_TRANSCRIBE_CHUNK_SECONDS=30
# ALFRED_TRANSCRIBE_BATCH_SIZE=8
# ALFRED_TRANSCRIBE_MODEL_CACHE=.alfred-runtime/models/transcription
